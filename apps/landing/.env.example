# Copy to `.env` for local dev (`cp .env.example .env`). On Vercel, set these in
# Project → Settings → Environment Variables (Production scope) instead.

# URLs of the other apps (login redirects here by role).
# Local defaults below; on Vercel use the real deploy URLs.
VITE_PORTAL_URL=http://localhost:5174
VITE_ADMIN_URL=http://localhost:5175

# Mock API toggle. "enabled" → MSW serves /api/* from mock data (UI phase).
# To use a real backend later: set "disabled" and set VITE_API_URL.
VITE_API_MOCKING=enabled
